+			}
+			if err := removeDeletedOutputs(outDir, current, next); err != nil {
+				return err
+			}
+
+			fmt.Fprintf(os.Stderr, "recompiled %d changed file(s): %s\n", len(changed), strings.Join(changed, ", "))
+			current = next
+		}
+	}
+}
